{
  "uid": "loki-logs-custom",
  "title": "Logs — TestPlatform",
  "tags": ["loki", "logs"],
  "timezone": "browser",
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values(service)",
        "current": {"text": "All", "value": "$__all"},
        "includeAll": true,
        "allValue": ".+",
        "refresh": 2
      },
      {
        "name": "search",
        "type": "textbox",
        "current": {"text": "", "value": ""},
        "label": "Search"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total logs / min",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "datasource": "Loki",
      "targets": [{
        "expr": "sum(count_over_time({service=~\"$service\"} [$__interval]))",
        "legendFormat": "logs"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 2000}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Errors / min",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "datasource": "Loki",
      "targets": [{
        "expr": "sum(count_over_time({service=~\"$service\"} |~ \"(?i)error\" [$__interval]))",
        "legendFormat": "errors"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "5xx errors / min",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "datasource": "Loki",
      "targets": [{
        "expr": "sum(count_over_time({service=\"nginx\"} |~ \"\\\" 5[0-9][0-9] \" [$__interval]))",
        "legendFormat": "5xx"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Warnings / min",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "datasource": "Loki",
      "targets": [{
        "expr": "sum(count_over_time({service=~\"$service\"} |~ \"(?i)warn\" [$__interval]))",
        "legendFormat": "warnings"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "orange", "value": 10}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Log volume by service",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 5},
      "datasource": "Loki",
      "targets": [{
        "expr": "sum by (service) (count_over_time({service=~\"$service\"} [$__interval]))",
        "legendFormat": "{{service}}"
      }],
      "options": {"tooltip": {"mode": "multi"}},
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "bars", "stacking": {"mode": "normal"}, "fillOpacity": 50}
        }
      }
    },
    {
      "id": 6,
      "title": "Error log volume",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 12},
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\"} |~ \"(?i)error\" [$__interval]))",
          "legendFormat": "error — {{service}}"
        },
        {
          "expr": "sum(count_over_time({service=\"nginx\"} |~ \"\\\" 5[0-9][0-9] \" [$__interval]))",
          "legendFormat": "5xx nginx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"drawStyle": "bars", "fillOpacity": 70},
          "color": {"mode": "palette-classic"}
        }
      }
    },
    {
      "id": 7,
      "title": "Live logs",
      "type": "logs",
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 19},
      "datasource": "Loki",
      "targets": [{
        "expr": "{service=~\"$service\"} |~ \"$search\"",
        "legendFormat": ""
      }],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 38
}
